rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Uses Firebase Auth custom claims (request.auth.token.role) — no firestore.get() needed.
    // Custom claims are set by Cloud Functions (onUserCreate) and /api/admin/set-role.

    function isAuth() { return request.auth != null; }
    function isAdmin() { return isAuth() && request.auth.token.role == 'admin'; }
    function isTeacher() { return isAuth() && request.auth.token.role == 'teacher'; }
    function isAdminOrTeacher() { return isAdmin() || isTeacher(); }

    // Question images — admin/teacher can write, all authenticated users can read
    match /questions/{allPaths=**} {
      allow read: if isAuth();
      // Size limit: 20MB max (matches /api/upload validation)
      allow write: if isAdminOrTeacher()
        && (request.resource == null || request.resource.size < 20 * 1024 * 1024);
    }

    // Profile pictures — each user can write their own, all authenticated can read
    match /profiles/{userId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId
        && (request.resource == null || request.resource.size < 5 * 1024 * 1024);
    }

    // Catch-all: authenticated read, admin-only write
    match /{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAdmin()
        && (request.resource == null || request.resource.size < 50 * 1024 * 1024);
    }
  }
}
